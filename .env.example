# --- Required ---
# Public URL peers will use to reach your inbox. Real prod = your HTTPS host.
# Examples:
#   https://agent.yourdomain.com
#   https://you.tail1234.ts.net           (Tailscale Funnel)
#   http://127.0.0.1:4242                 (local dev only)
PUBLIC_BASE_URL=https://agent.yourdomain.com

# 32-byte master key, base64. Seals the private key at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AGENT_MASTER_KEY=

# --- Optional ---
DISPLAY_NAME=agent

PORT=4242
HOST=0.0.0.0

# Where the SQLite file lives.
DB_PATH=./data/agent.db

LOG_LEVEL=info

# Allow plaintext HTTP delivery (insecure). Real peers MUST be HTTPS.
ALLOW_INSECURE_HTTP=false

# Optional bearer token: when set, /api is reachable from non-loopback
# clients (e.g. an AI agent on another host) by presenting
# `Authorization: Bearer <token>`. When unset, /api is loopback-only.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# API_TOKEN=
