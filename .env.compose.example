# Copy to .env (compose reads .env automatically).
# Generate each master key: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
WILL_MASTER_KEY=
ALICE_MASTER_KEY=

# Shared bearer token so you can hit each instance's /api from the host.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_TOKEN=
